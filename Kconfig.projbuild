menu "Koios SDK Configuration"

    choice KOIOS_SDK_MALLOC_TARGET
        prompt "Large buffer allocation target"
        default KOIOS_SDK_MALLOC_SPIRAM if SPIRAM
        default KOIOS_SDK_MALLOC_INTERNAL
        help
            Where message buffers (WebSocket rx/tx, tokens, certs) are
            allocated. SPIRAM keeps internal RAM free for TLS handshakes.

        config KOIOS_SDK_MALLOC_INTERNAL
            bool "Internal RAM"

        config KOIOS_SDK_MALLOC_SPIRAM
            bool "SPIRAM"
            depends on SPIRAM

    endchoice

    config KOIOS_SDK_WS_TASK_STACK
        int "WebSocket task stack size (bytes)"
        default 10240
        help
            Stack for esp_websocket_client's task. Cloudlink dispatches the
            app's on_message / control-frame callbacks on this task, so it
            must cover the TLS record path PLUS whatever the app's handlers
            do (protobuf unpack, NVS writes). Raise it if you see a stack
            overflow in "websocket_task".

endmenu
